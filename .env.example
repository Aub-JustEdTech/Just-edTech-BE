# ====================================
# Application Configuration
# ====================================
API_V1_STR=/api/v1
PROJECT_NAME=Just-EdTech

# ====================================
# Security
# ====================================
SECRET_KEY=your-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ====================================
# Database Configuration (PostgreSQL)
# ====================================
# Local dev: Postgres runs on the host machine, not in Docker.
# Use host.docker.internal so Docker containers can reach the host's Postgres.
# Production: set to your RDS endpoint (e.g. mydb.xxxx.rds.amazonaws.com).
POSTGRES_SERVER=host.docker.internal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=just_edtech
POSTGRES_PORT=5432
# Set to "require" for RDS/production, leave empty for local dev.
POSTGRES_SSLMODE=

# ====================================
# Redis Configuration
# ====================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REFRESH_TOKEN_EXPIRE_DAYS=30

# ====================================
# CORS Configuration
# ====================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# ====================================
# RAG Configuration
# ====================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_TOKENS=4000

# ====================================
# Vector Store Configuration
# ====================================
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_PREFIX=tenant

# Future: Pinecone Configuration (Optional)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-pinecone-environment

# Future: Weaviate Configuration (Optional)
# WEAVIATE_URL=http://localhost:8080

# ====================================
# OpenAI Configuration
# ====================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ====================================
# AWS S3 Configuration
# ====================================
S3_BUCKET_NAME=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ====================================
# Document Processing Configuration
# ====================================
MAX_FILE_SIZE_MB=50
ALLOWED_DOCUMENT_TYPES=[".pdf", ".md", ".txt", ".docx"]
TEMP_UPLOAD_DIR=./temp_uploads
